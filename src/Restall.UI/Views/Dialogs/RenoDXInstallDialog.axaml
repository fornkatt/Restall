<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:dto="clr-namespace:Restall.Application.DTOs;assembly=Restall.Application"
		xmlns:vm="clr-namespace:Restall.UI.ViewModels.Dialogs"
		x:Class="Restall.UI.Views.Dialogs.RenoDXInstallDialog"
		x:DataType="vm:RenoDXInstallDialogViewModel"
		Title="Install RenoDX Nightly"
		Width="340"
		SizeToContent="Height"
		WindowStartupLocation="CenterOwner"
		SystemDecorations="None"
		CanResize="False"
		Background="Transparent"
		TransparencyLevelHint="Transparent"
		ClipToBounds="True">

	<Border Background="{DynamicResource AppBackground}"
			CornerRadius="10"
			BorderBrush="{DynamicResource DialogBorder}"
			BorderThickness="1"
			ClipToBounds="True">
		<Border.Styles>
			<Style Selector="ListBoxItem">
				<Setter Property="Padding" Value="0"/>
				<Setter Property="Background" Value="Transparent"/>
			</Style>
			<Style Selector="ListBoxItem:selected /template/ ContentPresenter">
				<Setter Property="Background" Value="Transparent"/>
			</Style>
			<Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
				<Setter Property="Background" Value="Transparent"/>
			</Style>

			<Style Selector="ListBoxItem:pointerover RadioButton /template/ Ellipse#OuterEllipse">
				<Setter Property="Stroke" Value="{DynamicResource SystemAccentColor}"/>
				<Setter Property="Fill" Value="#20FFFFFF"/>
			</Style>
		</Border.Styles>

		<Grid Grid.ColumnDefinitions="0.5*, 0.5*"
			  Grid.RowDefinitions="Auto, Auto, Auto, Auto">
			<ListBox Grid.Row="0"
					 Grid.ColumnSpan="2"
					 ItemsSource="{Binding AvailableVersions}"
					 SelectedItem="{Binding SelectedVersion}"
					 SelectionMode="Single"
					 Background="Transparent"
					 MaxHeight="200"
					 ClipToBounds="True">
				<ListBox.ItemTemplate>
					<DataTemplate x:DataType="dto:RenoDXTagInfoDto">
						<RadioButton Content="{Binding Version}"
									 IsChecked="{Binding $parent[ListBoxItem].IsSelected}"
									 IsHitTestVisible="True"
									 Margin="4, 2"
									 ClipToBounds="True"/>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>
			<Separator Grid.Row="1"
					   Grid.ColumnSpan="2"
					   Margin="10, 8, 10, 0"
					   Background="{DynamicResource GameCardBackground}"
					   IsVisible="{Binding HasCommitNotes}"
					   Height="2"/>
			<Border Grid.Row="2"
					Grid.ColumnSpan="2"
					IsVisible="{Binding HasCommitNotes}"
					Margin="8, 15, 8, 8"
					Padding="6"
					Background="{DynamicResource GameCardBackground}"
					CornerRadius="4">
				<StackPanel>
					<TextBlock Text="Commit Notes"
							   FontSize="12"
							   FontWeight="Bold"
							   Foreground="{DynamicResource GameCardText}"
							   Margin="0,0,0,4"/>
					<ItemsControl ItemsSource="{Binding CommitNotes}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="x:String">
								<TextBlock Text="{Binding}"
										   FontSize="11"
										   TextWrapping="Wrap"
										   Margin="0,1"/>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>

			<Button Grid.Row="3"
					Grid.Column="0"
					Margin="10"
					Content="Confirm"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					HorizontalContentAlignment="Center"
					VerticalContentAlignment="Center"
					Command="{Binding ConfirmCommand}"
					MinWidth="80"
					CornerRadius="5"
					Background="{DynamicResource ModCardButton}"
					Foreground="{DynamicResource ModCardButtonText}"/>
			<Button Grid.Row="3"
					Grid.Column="1"
					Margin="10"
					Content="Cancel"
					HorizontalAlignment="Center"
					VerticalAlignment="Center"
					HorizontalContentAlignment="Center"
					VerticalContentAlignment="Center"
					Command="{Binding CancelCommand}"
					MinWidth="80"
					CornerRadius="5"
					Background="{DynamicResource ModCardButton}"
					Foreground="{DynamicResource ModCardButtonText}"/>
		</Grid>
	</Border>

</Window>