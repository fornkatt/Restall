<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:Restall.UI.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="1200"
		x:Class="Restall.UI.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		Icon="/Assets/avalonia-logo.ico"
		Title="Restall"
		Width="1000"
		Height="1200"
		Background="{DynamicResource AppBackground}">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<Grid.RowDefinitions>
			<RowDefinition Height="280"/>
			<RowDefinition Height="*"/>
		</Grid.RowDefinitions>

		<ContentControl Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Content="{Binding BannerViewModel}"/>
		<ContentControl Grid.Row="1" Grid.Column="0" Content="{Binding GameListViewModel}"/>
		<ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding ModViewModel}"/>

	</Grid>


</Window>
